<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="hell-page" data-world="hell">
  <div class="app-shell">
    <!-- Top Bar -->
    <header class="topbar">
      <div class="topbar-left"></div>

      <div class="brand">
        <div>
          <div class="brand-title">HELL NETWORK</div>
          <div class="brand-subtitle">BUILD THE WORLD WE FEAR</div>
        </div>
      </div>

      <div class="topbar-right"></div>
    </header>

    <!-- Main Area -->
    <main class="workspace">
      <!-- Left Sidebar -->
      <aside class="sidebar left">
        <section class="panel info-panel">
          <div class="panel-header">HELL MODE</div>
          <div class="panel-body">
            <p>
              This is your space to imagine collapse, corruption, and the world below.
            </p>
            <p>
              Choose images from the archive and drag them into the abyss.
            </p>
            <p class="bold">Break down. Burn away. Begin again.</p>
          </div>
        </section>

        <section class="panel canvas-info-panel">
          <div class="panel-header">CANVAS INFO</div>
          <div class="panel-body small">
            <div>X: <span id="mouseX">0</span>, Y: <span id="mouseY">0</span></div>
          </div>
        </section>

        <section class="portal-zone">
          <a href="/heaven" class="portal-link">
            <img src="/assets/heaven-button.jpg" alt="Return to Heaven" class="portal-img"  />
        <span class = "portal-label">
<p>RISE TO HEAVEN</p>
           </span>
          </a>
        </section>
      </aside>

      <!-- Center Canvas -->
      <section class="canvas-wrap">
        <div
          class="canvas-stage"
          data-world="hell"
        >
          <canvas
            id="mainCanvas"
            width="1600"
            height="900"
          ></canvas>
        </div>
      </section>

      <!-- Right Sidebar -->
      <aside class="sidebar right">
        <section class="panel archive-panel">
          <div class="panel-header archive-header">
            <span>IMAGE ARCHIVE</span>
          </div>

          <div class="archive-tools">
            <input type="file" id="assetUpload" accept="image/*" hidden />
            <button type="button" id="uploadBtn" class="upload-btn">Upload Image</button>

            <button type="button" id="drawBtn" class="upload-btn">
              Draw Mode: Off
            </button>

            <div class="brush-inputs">
              <input type="color" id="brushColor" value="#ff2a2a" />

              <input type="range" id="brushSize" min="1" max="30" value="4" />
            </div>

            <div class="secret-button">
              <button type="button" id="whisperBtn" class="whisper-btn hell-whisper">
                speak the forgotten word
              </button>
            </div>

            <div class="upload-status-container">
              <div id="uploadStatus" class="upload-status"></div>
            </div>
          </div>

          <div class="asset-scroll">
            {% for img in assets %}
            <img src="{{ img }}" class="thumb" data-src="{{ img }}" alt="asset">
            {% endfor %}
          </div>

          <div class="archive-footer">
            <p>DRAG OR CLICK AN IMAGE TO ADD TO CANVAS.</p>
          </div>
          <div class="word-bank-wrap">
            <div class="word-bank-header">
              <span>WORD BANK</span>
              <button type="button" id="refreshWordsBtn" class="mini-tool-btn">Refresh</button>
            </div>

            <div id="wordBank" class="word-bank"></div>
          </div>
        </section>
      </aside>
    </main>

    <!-- Bottom Bar -->
    <footer class="bottombar">
      <div class="status">WELCOME TO HELL. EVERY PIXEL IS A WARNING.</div>
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/fabric@4.6.0/dist/fabric.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>

  <script>
    window.WORLD = document.body.dataset.world;
  </script>

  <script src="/js/script.js"></script>
</body>

</html>
