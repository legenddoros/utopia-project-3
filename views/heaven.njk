<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body data-world="heaven">
  <div class="app-shell">
    <!-- Top Bar -->
    <header class="topbar">
      <div class="topbar-left">
        <a href="/" class="top-nav-btn">HOME</a>
        <button type="button" id="openAboutBtn" class="top-nav-btn">ABOUT</button>
      </div>

      <div class="brand">
        <div>
          <div class="brand-title">UTOPIA NETWORK</div>
          <div class="brand-subtitle">BUILD THE WORLD WE WANT</div>
        </div>
      </div>

      <div class="topbar-right"></div>
    </header>

    <!-- Main Area -->
    <main class="workspace">
      <!-- Left Sidebar -->
      <aside class="sidebar left">
        <section class="panel info-panel" id="aboutPanel">
          <div class="panel-header">UTOPIA MODE</div>
          <div class="panel-body">
            <p>
              This is your space to imagine, create, and share the world we want to live in.
            </p>
            <p>
              Choose images from the archive and add them to your canvas.
            </p>
            <p class="bold">Build together. Dream together.</p>
          </div>
        </section>

        <section class="panel canvas-info-panel">
          <div class="panel-header">CANVAS INFO</div>
          <div class="panel-body small">
            <div>X: <span id="mouseX">0</span>, Y: <span id="mouseY">0</span></div>
          </div>
        </section>

        <section class="rabbit-zone">
          
          <a href="/hell" class="rabbit-link">
            <img src="/assets/hell-button.png" alt="Rabbit Hole" class="rabbit-hole-img" />
           <span class = "rabbit-label">
<p>ENTER THE UNDERWORLD</p>
           </span>
          </a>
           
        </section>
       
      </aside>

      <!-- Center Canvas -->
      <section class="canvas-wrap">
        <div
          class="canvas-stage"
          data-world="heaven"
        >
          <canvas
            id="mainCanvas"
            width="1600"
            height="900"
          ></canvas>
        </div>
      </section>

      <!-- Right Sidebar -->
      <aside class="sidebar right">
        <section class="panel archive-panel">
          <div class="panel-header archive-header">
            <span>IMAGE ARCHIVE</span>
          </div>

          <div class="archive-tools">
            <input type="file" id="assetUpload" accept="image/*" hidden />
            <button type="button" id="uploadBtn" class="upload-btn">Upload Image</button>

            <button type="button" id="drawBtn" class="upload-btn">
              Draw Mode: Off
            </button>
            <button type="button" id="eraseBtn" class="upload-btn">
              Erase Selected
            </button>

            <div class="brush-inputs">
              <input type="color" id="brushColor" value="#7ec8ff" />

              <input type="range" id="brushSize" min="1" max="30" value="4" />
            </div>

            <div class="secret-button">
              <button type="button" id="whisperBtn" class="whisper-btn">
                remember eden
              </button>
            </div>

            <div class="upload-status-container">
              <div id="uploadStatus" class="upload-status"></div>
            </div>
          </div>

          <div class="asset-scroll">
            {% for img in assets %}
            <img src="{{ img }}" class="thumb" data-src="{{ img }}" alt="asset">
            {% endfor %}
          </div>

          <div class="archive-footer">
            <p>DRAG OR CLICK AN IMAGE TO ADD TO CANVAS.</p>
          </div>
          <div class="word-bank-wrap">
            <div class="word-bank-header">
              <span>WORD BANK</span>
              <button type="button" id="refreshWordsBtn" class="mini-tool-btn">Refresh</button>
            </div>

            <div id="wordBank" class="word-bank"></div>
          </div>
        </section>
      </aside>
    </main>

    <!-- Bottom Bar -->
    <footer class="bottombar">
      <div class="status">WELCOME TO UTOPIA. EVERY PIXEL IS A POSSIBILITY.</div>
    </footer>
  </div>

  <div id="aboutModal" class="about-modal hidden">
    <div class="about-modal-box">
      <button type="button" id="closeAboutBtn" class="about-close-btn">X</button>

      <h2>About This Project</h2>

      <p>
        Utopia Network is a speculative communication project where users build
        visual worlds through images, drawing, and interaction.
      </p>

      <p>
        The project was created to explore how people might communicate through
        visual symbols instead of only using normal text. In this space, users
        can imagine hopeful futures and create a shared utopian world.
      </p>

      <p>
        This project was built with Express, Nunjucks, Fabric.js, HTML, CSS, and
        JavaScript. The backend helps render the pages and organize uploaded
        images, while the frontend allows users to interact with the canvas.
      </p>

      <p>
        The main goal of the project is to make communication feel more visual,
        playful, and collaborative.
      </p>
    </div>
  </div>
<!-- Heaven Audio -->
  <!-- Heaven Audio -->
<audio id="pageAudio" autoplay loop>
  <source src="/assets/audio/heaven.mp3" type="audio/mpeg">
</audio>

<button id="audioToggle" class="audio-btn heaven-audio-btn">
  Disable Sound
</button>

<script src="/js/audio.js"></script>

  <script src="https://cdn.jsdelivr.net/npm/fabric@4.6.0/dist/fabric.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>

  <script>
    window.WORLD = document.body.dataset.world;
  </script>

  <script src="/js/script.js"></script>
</body>

</html>
